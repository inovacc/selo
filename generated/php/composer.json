{
    "name": "selo/generated",
    "description": "Code generated by selo gen --lang php. Brazilian-document validation, formatting, and origin.",
    "type": "library",
    "license": "BSD-3-Clause",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Selo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Selo\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
